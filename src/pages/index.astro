---
import PageLayout from '../layouts/PageLayout.astro';
const allPosts = Object.values(import.meta.glob('./notebook/*.md', { eager: true }));
const pageTitle = "Thamara Kandabada - Home";

export const prerender = false;

// Tell the CDN to keep separate caches based on the User-Agent
Astro.response.headers.set('Vary', 'User-Agent');

// Grab the user agent and convert to lowercase
const userAgent = (Astro.request.headers.get('user-agent') || '').toLowerCase();

if (userAgent.includes('curl')) {
  const terminalText = `

//////////////////////////////////////////////////////////////////////////
//                                                                      //
//  ‚ĖĎ‚ĖÄ‚Ėą‚ĖÄ‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖĄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖÄ‚Ėą  //
//  ‚ĖĎ‚ĖĎ‚Ėą‚ĖĎ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚ĖĎ‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚ĖĄ‚ĖĎ‚Ėą‚ĖÄ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖĎ‚Ėą‚ĖÄ‚Ėą  //
//  ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ‚ĖÄ‚ĖĎ‚ĖĎ‚ĖÄ‚ĖĎ‚ĖÄ  //
//                                                                      //
//////////////////////////////////////////////////////////////////////////

Hello, command line visitor. I bid you good timezone.
==========================================================================

Thank you for stopping by. I‚Äôm Thamara, furniture-peddler by day and
wearer-of-many-hats by night. Currently based in Belfast, UK.

Visit my website: https://thamara.co.uk
See what's happening now: https://thamara.co.uk/now
Read the blog: https://thamara.co.uk/notebook

Contact:
-----------
Send me an email: t@thamara.co.uk

Elsewhere:
-----------
LinkedIn: https://www.linkedin.com/in/thamarakandabada/
Reddit: https://www.reddit.com/user/thamara-k/
GitHub: https://github.com/thamarakandabada

==========================================================================
ASCII art by https://www.asciiart.eu/
`;

  // Calculate the exact file size so Windows curl knows when to exit
  const byteLength = new TextEncoder().encode(terminalText).length.toString();

  return new Response(terminalText, {
    headers: {
      'Content-Type': 'text/plain; charset=utf-8',
      'Vary': 'User-Agent',
      'Content-Length': byteLength,
      'Connection': 'close'
    }
  });
}
---

<PageLayout title={pageTitle}>
  <h1>Greetings, friends & strangers.</h1>
  <div class="home-page-hero">
    <div class="home-page-intro">
      <p>Welcome to my personal website.</p>
      <p>I‚Äôm Thamara, <a href="/resume">furniture-peddler</a> by day and <a href="/now">wearer-of-many-hats</a> by night. Currently based in Belfast, Northern Ireland.</p></p>
      <p>I‚Äôve had a website since 2014, which was when I first learned the basics of web design‚ÄĒspecifically, HTML, CSS, and WordPress. This is the fourth or fifth iteration; I‚Äôve now lost count.</p>
      <p>You can learn more about how this site is built in <a href="/colophon">the colophon</a>, or explore below. Bust most importantly, thank you for visiting. Please consider signing my <a href="/guestbook">guestbook</a>.</p>
    </div>

    <div class="home-page-hero-image">
      <img src="#" alt="" width="100%"/>
    </div>
  
  </div>

  <h2>Explore my digital garden</h2>

  <div class="homepage-flex">
    <div  class="featured-pages">   
      <h3>At a glance</h3>
        <ul class="featured-pages-list">
          <li><a href="/resume">Resume</a></li>
          <li><a href="/now">What I'm up to</a></li>
          <li><a href="/uses">What I'm using</a></li>
          <li><a href="/gigs">Gigs I've been to</a></li>
          <li><a href="https://physicalmedia.thamara.co.uk">Blu-ray collection</a></li>
          <li><a href="/hello">Say hello</a></li>
        </ul>
    </div>
    <div class="recent-blogposts">
      <h3>From the notebook</h3>
        <ul class="recent-blogposts-list">
          {allPosts.map((post: any) => <li><a href={post.url}>{post.frontmatter.title}</a></li>)}
        </ul>
    </div>
    <div class="webrings">
      <h3>See the neighbourhood</h3>
        <p>This website is part of the IndieWeb Webring. View more sites like this below.</p>
        <ul class="webring-links">
          <li><a href="/">Previous</a></li>
          <li><a href="/">Random</a></li>
          <li><a href="/">Next</a></li>
