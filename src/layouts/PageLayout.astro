---
import "../styles/global.css";
import Navigation from "../components/TopNavigation.astro";
import GlobalFooter from "../components/GlobalFooter.astro";

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<script is:inline>
          const theme = (() => {
            // Check if they manually selected a theme previously
            if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
            return localStorage.getItem('theme');
            }
            // Otherwise, check their operating system preference
            if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
            return 'dark';
            }
            return 'light';
          })();
    
          // Apply the theme to the HTML tag immediately
          if (theme === 'light') {
          document.documentElement.setAttribute('data-theme', 'light');
          } else {
          document.documentElement.setAttribute('data-theme', 'dark');
          }
          window.localStorage.setItem('theme', theme);
        </script>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href="/tk.png" />
		<link rel="icon" href="/favicon.ico" />
        <link rel="stylesheet" href="https://use.typekit.net/lbp7mnn.css">
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>	
		<Navigation />
		<div class="page-content">
		<slot />
		</div>   
		<GlobalFooter />
		<script>
    const themeToggle = document.getElementById('theme-toggle');

    // 1. Sync the checkbox state with the current theme on page load
    if (document.documentElement.getAttribute('data-theme') === 'dark') {
      themeToggle.checked = true;
    }

    // 2. Listen for clicks on the toggle
    themeToggle.addEventListener('change', () => {
      if (themeToggle.checked) {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
      } else {
        document.documentElement.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
      }
    });
    </script>
	</body>
</html>
